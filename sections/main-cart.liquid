<section id="shopping-cart" class="bg-brand-dark min-h-screen py-32 md:py-40 relative">
    <div class="noise-overlay"></div>
    <div class="relative z-10 w-full max-w-5xl mx-auto px-6">
        
        <div class="mb-12 md:mb-16">
            <h1 class="font-arabic text-4xl md:text-5xl text-brand-cream mb-2">سلة المشتريات</h1>
            <h2 class="font-display italic text-xl tracking-widest text-brand-gold">Shopping Cart</h2>
        </div>

        {% if cart.item_count == 0 %}
            <div class="text-center py-20 border border-brand-gold/10 bg-brand-dark/50 p-10 rounded-sm">
                <p class="font-arabic-sans text-xl text-brand-cream mb-4">سلة المشتريات فارغة</p>
                <p class="font-modern uppercase tracking-widest text-brand-cream/50 text-xs mb-10">Your cart is currently empty.</p>
                <a href="{{ routes.collections_url }}" class="inline-block px-10 py-4 bg-brand-gold text-brand-dark font-modern uppercase tracking-[0.2em] text-xs font-bold hover:bg-brand-cream transition-colors">
                    Continue Shopping
                </a>
            </div>
        {% else %}
            {% form 'cart', cart, id: 'cart-form', class: 'flex flex-col gap-10' %}
                
                <!-- Line Items -->
                <div class="flex flex-col gap-6">
                    {% for item in cart.items %}
                        <div class="flex flex-col md:flex-row items-center gap-6 p-6 border border-brand-gold/20 bg-brand-dark/30 hover:bg-brand-dark/80 transition-colors relative">
                            
                            <!-- Remove Button -->
                            <a href="{{ item.url_to_remove }}" class="absolute top-4 right-4 md:static text-brand-cream/30 hover:text-red-400 transition-colors" title="Remove {{ item.title | escape }}">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                            </a>

                            <!-- Image -->
                            <a href="{{ item.url }}" class="w-24 h-24 shrink-0 bg-brand-dark flex items-center justify-center border border-brand-gold/10">
                                {% if item.image %}
                                    <img src="{{ item.image | img_url: '200x200' }}" alt="{{ item.title | escape }}" class="w-full h-full object-contain p-2">
                                {% else %}
                                    <span class="text-3xl">🪵</span>
                                {% endif %}
                            </a>

                            <!-- Info -->
                            <div class="flex-grow text-center md:text-left">
                                <a href="{{ item.url }}" class="font-arabic text-2xl md:text-3xl text-brand-cream hover:text-brand-gold transition-colors block mb-1">{{ item.product.title }}</a>
                                {% unless item.product.has_only_default_variant %}
                                    <p class="font-display italic text-brand-cream/50 text-sm">{{ item.variant.title }}</p>
                                {% endunless %}
                            </div>

                            <!-- Controls -->
                            <div class="flex items-center gap-8 md:gap-12 mt-4 md:mt-0">
                                <div class="flex items-center border border-brand-gold/30 rounded-sm overflow-hidden">
                                    <button type="button" class="w-10 h-10 flex items-center justify-center text-brand-cream hover:bg-brand-gold/10 transition-colors" onclick="this.nextElementSibling.stepDown(); this.nextElementSibling.form.submit();">-</button>
                                    <input type="number" name="updates[]" id="updates_{{ item.key }}" value="{{ item.quantity }}" min="0" class="w-12 h-10 bg-transparent text-center font-mono text-brand-cream outline-none focus:ring-0 focus:border-brand-gold appearance-none m-0" onchange="this.form.submit()">
                                    <button type="button" class="w-10 h-10 flex items-center justify-center text-brand-cream hover:bg-brand-gold/10 transition-colors" onclick="this.previousElementSibling.stepUp(); this.previousElementSibling.form.submit();">+</button>
                                </div>
                                <div class="font-mono text-lg font-bold text-brand-gold min-w-[100px] text-right">
                                    {{ item.final_line_price | money }}
                                </div>
                            </div>
                            
                        </div>
                    {% endfor %}
                </div>

                <!-- Summary Footer -->
                <div class="border-t border-brand-gold/20 pt-10 flex flex-col md:flex-row justify-between items-start md:items-end gap-8">
                    <div class="w-full md:w-1/2">
                        <label for="CartNote" class="block font-modern uppercase tracking-widest text-xs text-brand-cream/60 mb-3">Order Notes / رسالة خاصة</label>
                        <textarea name="note" id="CartNote" rows="3" class="w-full bg-brand-dark/50 border border-brand-gold/30 text-brand-cream p-4 outline-none focus:border-brand-gold transition-colors resize-none placeholder:text-brand-cream/20" placeholder="Any special instructions or calligraphy requests?">{{ cart.note }}</textarea>
                    </div>

                    <div class="w-full md:w-auto flex flex-col items-end gap-6 text-right">
                        <div class="flex items-baseline justify-between w-full md:w-auto md:justify-end gap-8 border-b border-brand-gold/10 pb-4">
                            <span class="font-modern uppercase tracking-widest text-brand-cream/60 text-sm">Subtotal</span>
                            <span class="font-mono text-3xl font-bold text-brand-gold">{{ cart.total_price | money }}</span>
                        </div>
                        <p class="font-display italic text-brand-cream/40 text-sm">Taxes and shipping calculated at checkout</p>
                        
                        <div class="w-full flex flex-col md:flex-row gap-4 justify-end mt-2">
                            <button type="submit" name="update" class="px-8 py-4 border border-brand-gold/50 text-brand-cream hover:bg-brand-gold/10 transition-colors font-modern uppercase tracking-widest text-xs font-bold text-center">
                                Update
                            </button>
                            <button type="submit" name="checkout" class="px-12 py-4 bg-brand-gold text-brand-dark hover:bg-brand-cream transition-colors font-modern uppercase tracking-[0.2em] text-sm font-bold shadow-[0_0_20px_rgba(184,150,46,0.2)] text-center flex items-center justify-center gap-3">
                                Checkout
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m9 18 6-6-6-6"/></svg>
                            </button>
                        </div>
                    </div>
                </div>

            {% endform %}
        {% endif %}

    </div>
</section>

{% schema %}
{
  "name": "Cart Main",
  "settings": [],
  "presets": [
    {
      "name": "Cart Main"
    }
  ]
}
{% endschema %}
